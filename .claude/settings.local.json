{
  "permissions": {
    "allow": [
      "Skill(update-config)",
      "Bash(npm run build)",
      "Bash(git add -A)",
      "Bash(git commit:*)",
      "Bash(git push:*)",
      "mcp__Claude_Preview__preview_start",
      "mcp__supabase__execute_sql",
      "mcp__supabase__apply_migration"
    ]
  },
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "cd \"C:/Dev/kind-collective/kc-tasks\" && if [ -n \"$(git status --porcelain)\" ]; then npm run build && git add -A && git commit -m \"feat: update KC Tasks $(date +%Y-%m-%d)\" && git push; fi",
            "timeout": 120,
            "statusMessage": "Building and deploying to GitHub..."
          }
        ]
      }
    ]
  }
}
